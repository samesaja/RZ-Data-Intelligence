# ═══════════════════════════════════════════════════════════════
# RZ Data Intelligence — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and update the values before deployment.
#
#   cp .env.example .env
#   # Edit .env with your production credentials
#   docker compose up -d
#

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=rz_user
POSTGRES_PASSWORD=rz_secret_password_change_me
POSTGRES_DB=rz_data_intelligence

# Async driver (used by FastAPI / SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Sync driver (used by Celery workers / Alembic)
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── FastAPI ──────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=false

# ── Next.js Frontend ────────────────────────────────────────
# When accessed via Nginx (port 80), the browser calls the API
# through the same origin. Leave empty to use relative URLs,
# or set to http://your-domain.com for explicit origin.
NEXT_PUBLIC_API_URL=
